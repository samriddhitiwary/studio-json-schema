{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/dependent-schemas-test",
  "title": "Test Schema for dependentSchemas",
  "description": "A schema demonstrating the dependentSchemas keyword handler",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "credit_card": {
      "type": "string",
      "pattern": "^[0-9]{16}$"
    },
    "billing_address": {
      "type": "string"
    },
    "cvv": {
      "type": "string",
      "pattern": "^[0-9]{3}$"
    },
    "employmentStatus": {
      "type": "string",
      "enum": ["employed", "self-employed", "unemployed"]
    },
    "employer": {
      "type": "string"
    },
    "jobTitle": {
      "type": "string"
    }
  },
  "dependentSchemas": {
    "credit_card": {
      "properties": {
        "billing_address": {
          "type": "string",
          "minLength": 10
        },
        "cvv": {
          "type": "string",
          "pattern": "^[0-9]{3}$"
        }
      },
      "required": ["billing_address", "cvv"]
    },
    "employmentStatus": {
      "if": {
        "properties": {
          "employmentStatus": {
            "enum": ["employed", "self-employed"]
          }
        }
      },
      "then": {
        "properties": {
          "employer": {
            "type": "string",
            "minLength": 1
          },
          "jobTitle": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["employer", "jobTitle"]
      }
    }
  }
}
